{
  // "Run and Debug" arranca el servidor de Next.js y abre el navegador
  // en la URL local. Antes abría el index.html estático viejo, por eso
  // no se veían los cambios al refrescar.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: dev server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
